# Agent Infrastructure – Configuration Example
# Copy this file to config.env and fill in your values.
# config.env is NOT tracked by git (see .gitignore).
#
# This file is sourced automatically by install.sh.
# You can also source it manually: source config.env

# ── Anthropic (orchestrator) ─────────────────────────────────
# Required: your Anthropic API key
export ANTHROPIC_API_KEY="sk-ant-REPLACE_WITH_YOUR_KEY"

# ── CERIT endpoint – pre-configured, do not change ──────────
export CERIT_API_KEY="REPLACE_WITH_CERIT_API_KEY"
export CERIT_BASE_URL="https://llm.ai.e-infra.cz/v1"

# ── CERIT model roles – set by install.sh after model selection ──
# Fill these in after running install.sh, or set them manually.
export CERIT_CODER_MODEL="REPLACE_WITH_SELECTED_MODEL"
export CERIT_THINKER_MODEL="REPLACE_WITH_SELECTED_MODEL"
export CERIT_FAST_MODEL="REPLACE_WITH_SELECTED_MODEL"
export CERIT_LIBRARIAN_MODEL="REPLACE_WITH_SELECTED_MODEL"

# ── Vault location ───────────────────────────────────────────
export VAULT="$HOME/vault"

# ── Agent infra repo location ────────────────────────────────
# Set automatically by install.sh
export AGENT_INFRA_DIR="REPLACE_WITH_REPO_PATH"

# ── Email reporting (optional) ───────────────────────────────
export AGENT_REPORT_EMAIL=""
export AGENT_FROM_EMAIL="agent@localhost"
export SMTP_HOST="localhost"
export SMTP_PORT="25"
